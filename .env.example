# Matrix configuration (all optional, defaults shown)
# MATRIX_PORT=47701
# MATRIX_DISCOVERY_PORT=47700
# MATRIX_MULTICAST_GROUP=239.255.77.88
# MATRIX_STALE_TIMEOUT=30.0
# MATRIX_ANNOUNCE_INTERVAL=5
# MATRIX_BT_SCAN_DURATION=4
# MATRIX_CHUNK_SIZE=65536
# MATRIX_MAX_PAYLOAD=16777216
# MATRIX_MAX_FILE_SIZE=10485760
# MATRIX_WS_PATH=/jump/ws
# MATRIX_WS_PORT=8443
# Required to listen on a public interface (an unauthenticated public bind is
# refused) and to gate the encrypted post-handshake AUTH exchange.
# MATRIX_AUTH_TOKEN=
# MATRIX_NODE_NAME=

# LLM / Director (all optional)
# MATRIX_LLM_BACKEND=ollama
# MATRIX_LLM_MODEL=
# MATRIX_LLM_ENDPOINT=http://127.0.0.1:11434
# MATRIX_LLM_API_KEY=
# MATRIX_LLM_TIMEOUT=30.0
# MATRIX_LLM_ACTION_BUDGET=5
# MATRIX_ESCALATION_COOLDOWN=60.0
# MATRIX_DEGRADED_SUSTAIN=10.0
# MATRIX_TASK_FAILURE_WINDOW=120.0
# MATRIX_TASK_FAILURE_THRESHOLD=5
